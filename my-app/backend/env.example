# ============================================
# Setup: copy this file to .env and fill in values
#   cp env.example .env
# ============================================

# --- Database (PostgreSQL) ---
DB_HOST=localhost
DB_NAME=liberia_ecommerce
DB_USER=your_database_username
DB_PASSWORD=your_database_password
DB_PORT=5432

# --- Stripe (Test mode) ---
# Dashboard → Developers → API keys: https://dashboard.stripe.com/test/apikeys
# Required for checkout and payments:
STRIPE_SECRET_KEY=sk_test_paste_your_secret_key_here

# Optional: only needed for /webhook (use Stripe CLI locally: stripe listen --forward-to localhost:8000/webhook)
STRIPE_WEBHOOK_SECRET=whsec_paste_webhook_signing_secret_here

# --- Email (SendGrid Web API — sent when /webhook receives checkout.session.completed) ---
# Create an API key: SendGrid → Settings → API keys
# Verify a sender (Single Sender or domain auth): same place as dashboard banner
SENDGRID_API_KEY=SG.paste_your_sendgrid_api_key_here
EMAIL_FROM=noreply@yourdomain.com
MERCHANT_EMAIL=you@yourdomain.com
# Optional: recipient for `python send_test_email.py` (defaults to MERCHANT_EMAIL)
# TEST_EMAIL_TO=you@yourdomain.com
# EU Data Residency only: set when using an EU-pinned subuser (calls set_sendgrid_data_residency)
# https://www.twilio.com/docs/sendgrid/data-residency
# SENDGRID_DATA_RESIDENCY=eu
