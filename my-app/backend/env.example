# ============================================
# Setup: copy this file to .env and fill in values
#   cp env.example .env
# ============================================

# --- Database (PostgreSQL) ---
DB_HOST=localhost
DB_NAME=liberia_ecommerce
DB_USER=your_database_username
DB_PASSWORD=your_database_password
DB_PORT=5432

# --- Stripe (Test mode) ---
# Dashboard → Developers → API keys: https://dashboard.stripe.com/test/apikeys
# Required for checkout and payments:
STRIPE_SECRET_KEY=sk_test_paste_your_secret_key_here

# Optional: only needed for /webhook (use Stripe CLI locally: stripe listen --forward-to localhost:8000/webhook)
STRIPE_WEBHOOK_SECRET=whsec_paste_webhook_signing_secret_here

# --- Email (order confirmations via SMTP when /webhook receives checkout.session.completed) ---
# Examples: Gmail (use an App Password), SendGrid SMTP, Mailgun, etc.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
# Use SMTP_SSL=true for port 465; leave false for STARTTLS on 587
SMTP_SSL=false
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@yourdomain.com
MERCHANT_EMAIL=you@yourdomain.com
