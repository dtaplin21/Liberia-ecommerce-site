# ============================================
# Setup: copy this file to .env and fill in values
#   cp env.example .env
# ============================================
#
# Stripe Test mode → Publishable key (same dashboard as the secret key):
#   https://dashboard.stripe.com/test/apikeys
#
# Used if you add Stripe.js / Elements later. Hosted Checkout (current flow)
# runs on Stripe’s site and only needs STRIPE_SECRET_KEY in backend/.env.
#
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_paste_your_publishable_key_here
